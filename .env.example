# Токен бота от @BotFather (https://t.me/intellectcentr_masterclass_bot)
BOT_TOKEN=123456:AAAA-replace-me

# Числовой Telegram ID владельца (узнать у @userinfobot). Нужен для /stats.
ADMIN_USER_ID=0

# Ссылка на комнату автовебинара (трансляция мастер-класса «5 навыков мозга»)
WEBINAR_URL=https://example.com/webinar

# Ссылка на регистрацию на бесплатный 6-дневный курс «Прокачка мозга» —
# выдаётся по кодовому слову ПРОКАЧКА
COURSE_URL=https://example.com/course

# Кодовое слово. Спец: ПРОКАЧКА. Бот принимает в любом регистре,
# включая транслитерацию prokachka/PROKACHKA.
SECRET_WORD=ПРОКАЧКА

# Путь к persistent-диску. На Amvera — /data. Локально — ./data
DATA_DIR=./data

# Часовой пояс для отображения дат пользователю
TZ=Europe/Moscow

# Уровень логов: INFO или DEBUG
LOG_LEVEL=INFO

# true — тайминги TG2..TG5 по минутам для smoke-теста (4 минуты на цепочку).
# В продакшене — false.
SMOKE_TEST=false
