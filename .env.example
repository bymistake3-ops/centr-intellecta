# Токен бота от @BotFather
BOT_TOKEN=123456:AAAA-replace-me

# Числовой Telegram ID владельца (узнать у @userinfobot)
ADMIN_USER_ID=0

# Ссылка на комнату автовебинара (Zoom/BBB/Kinescope/...)
WEBINAR_URL=https://example.com/webinar

# Ссылка на запись (заполнить после первого эфира; до этого можно оставить placeholder)
RECORD_URL=https://example.com/record

# Ссылка на бесплатный курс — выдаётся по кодовому слову
FREE_COURSE_URL=https://example.com/free-course

# Кодовое слово (регистронезависимо, пробелы по краям отрезаются)
SECRET_WORD=ИНТЕЛЛЕКТ

# Путь к persistent-диску. На Amvera — /data. Локально — ./data
DATA_DIR=./data

# Часовой пояс для отображения дат пользователю
TZ=Europe/Moscow

# Уровень логов: INFO или DEBUG
LOG_LEVEL=INFO

# true — тайминги T1..T6 по минутам для smoke-теста (6 минут на всю цепочку).
# В продакшене должно быть false.
SMOKE_TEST=false
